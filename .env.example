# =============================================================================
# Utility MCP Server — example environment variables.
# Copy to `.env` and customize for local development.
# =============================================================================

# --- HTTP server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- Pine Labs documentation source ---
PINELABS_DOCS_BASE_URL=https://vnykumargoyal.github.io/pinelabs-docs
PINELABS_DOCS_HTTP_TIMEOUT=10.0
PINELABS_DOCS_HTTP_RETRIES=2
PINELABS_DOCS_CACHE_TTL=300

# --- SDK download ---
SDK_DOWNLOAD_BASE_URL=https://github.com/prakhargour10/utility-mcp-server/raw/main/sdk

# --- Transport security (comma-separated) ---
ALLOWED_HOSTS=utility-mcp-server-production.up.railway.app,localhost:*,127.0.0.1:*

# =============================================================================
# Utility MCP Server — example environment variables.
# Copy to `.env` and customize for local development.
# =============================================================================

# --- HTTP server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- Pine Labs documentation (local) ---
PINELABS_DOCS_DIR=docs
PINELABS_SDK_DIR=docs/sdk

# --- SDK download ---
SDK_DOWNLOAD_BASE_URL=https://github.com/prakhargour10/utility-mcp-server/raw/main/docs/sdk

# --- Transport security (comma-separated) ---
ALLOWED_HOSTS=utility-mcp-server-production.up.railway.app,localhost:*,127.0.0.1:*

# --- RAG / vector search ---
# Where the FAISS index + chunks.json sidecar are stored.
PINELABS_DATA_DIR=data
# Sentence-transformers model id (small CPU-friendly default).
PINELABS_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Default number of hits returned by `search_documentation`.
PINELABS_RAG_TOP_K=5
# "1" (default) -> auto-build the FAISS index on first startup if missing.
# "0"           -> require an explicit `python -m utility_mcp_server.rag.build_index`.
PINELABS_RAG_AUTOBUILD=1

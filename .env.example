# =============================================================================
# Utility MCP Server — example environment variables.
# Copy to `.env` and customize for local development.
# =============================================================================

# --- HTTP server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# --- SDK download ---
SDK_DOWNLOAD_BASE_URL=https://github.com/prakhargour10/utility-mcp-server/raw/main/docs/sdk_list

# --- Transport security (comma-separated) ---
ALLOWED_HOSTS=utility-mcp-server-production.up.railway.app,localhost:*,127.0.0.1:*

# --- RAG pipeline ---
# Local directory containing the markdown documentation corpus that the
# RAG pipeline chunks + embeds. Defaults to <repo>/docs/doc_list.
RAG_RAW_DOCS_DIR=docs/doc_list
# Path to the persisted vector store (kept under data/ which is gitignored).
RAG_EMBEDDINGS_PATH=data/embeddings.json

# --- Local embeddings (sentence-transformers) ---
# Override to use a different local model. The default is small (~80MB)
# and produces 384-dim L2-normalized vectors.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

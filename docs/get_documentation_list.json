  },
  "cross_reference": {
    "do_transaction": {
      "request_model": "TransactionRequest",
      "result_model": "TransactionResult",
      "listener": "TransactionListener",
      "transport_specific_options": {
        "AppToApp": "AppToAppTransactionOptions",
        "Cloud": "CloudTransactionOptions",
        "PadController": "PadControllerTransactionOptions"
      },
      "related_concepts": [
        "lifecycle",
        "eventid-and-reconciliation",
        "error-handling",
        "transports"
      ]
    },
    "cancel": {
